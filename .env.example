# Configuración del Proyecto
# Copiar a .env y ajustar valores según necesidad

# ============================================================================
# DATA PIPELINE
# ============================================================================
TICKER=QQQ
START_DATE=2019-01-01
END_DATE=2024-04-20
LOOKBACK_DAYS=30

# ============================================================================
# MODELO LSTM
# ============================================================================
LSTM_HIDDEN_SIZE=64
LSTM_NUM_LAYERS=2
LSTM_DROPOUT=0.2
LSTM_OUTPUT_SIZE=16

# ============================================================================
# ENTRENAMIENTO
# ============================================================================
BATCH_SIZE=32
LEARNING_RATE=0.001
WEIGHT_DECAY=0.00001
NUM_EPOCHS=50
EARLY_STOPPING_PATIENCE=10
TRAIN_VAL_TEST_SPLIT=0.7,0.15,0.15

# ============================================================================
# DEVICE
# ============================================================================
# Options: cpu, cuda, mps (Apple)
DEVICE=cpu

# ============================================================================
# PATHS
# ============================================================================
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
MODELS_PATH=models
RESULTS_PATH=results
LOGS_PATH=logs

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
